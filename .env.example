# NLPL Status — local secrets / config.
# Copy this file to ".env" (same folder) and fill in real values.
# The backend loads it automatically on startup (backend/settings.py).

# --- Email (EOD report mailing) ---------------------------------------------
# Use a Gmail App Password (NOT your normal password):
#   https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Engine location (optional) ---------------------------------------------
# Defaults to ../unified-collection-report next to this project.
# UNIFIED_COLLECTION_DIR=C:\Users\you\Desktop\unified-collection-report

# --- Backend host/port (optional) -------------------------------------------
# NLPL_HOST=127.0.0.1
# NLPL_PORT=5055

# --- Supabase Sync (Grow_With_Me staging) -----------------------------------
# Service-role JWT (keep secret). Without it, Supabase sync returns
# "not configured". SUPABASE_URL has a sensible default already.
# SUPABASE_URL=https://knbijsnghjcaocwtjvvw.supabase.co
# SUPABASE_SERVICE_KEY=

# --- Disbursement Sync (Coll_Db EC2 Postgres) -------------------------------
# The push uses ssh+psql. Provide the SSH key path and (optionally) override
# the host / DB creds. Defaults match the source project.
# EC2_KEY_PATH=C:\Users\you\.ssh\aws-ec2.pem
# EC2_HOST=ec2-user@52.66.163.52
# EC2_PG_USER=
# EC2_PG_PASS=
# EC2_PG_DB=postgres

# --- Dashboard sync targets (optional) --------------------------------------
# COLLDB_URL=https://growwithme.navachetanalivelihoods.com
# EC2_UPLOAD_URL=

# NOTE: these may instead be placed in unified-collection-report/.env — the
# backend loads that engine .env too (this project's .env takes precedence).
